<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Welcome to the CSE 340 Service Network!</h2>
    <p>The following categories are as shown:</p>
    
    <!-- 1. Wrapped the loop inside a <ul> tag so the browser lists them properly -->
    <ul>
        <% categories.forEach(category => { %>
            <li>
                <a href="/category/<%= category.category_id %>">
                    <%= category.category_name %>
                </a>
            </li>
        <% }) %>
    </ul>

    <img class="main-logo" src="images/cse340-service-network.png" alt="CSE 340 Service Network Logo">

</main>

<%- include('partials/footer') %>