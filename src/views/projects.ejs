<%- include('partials/header') %>

<main>
  <h1><%= title %></h1>
  
  <ul class="projects-list">
    <% projects.forEach(project => { %>
      <li>
        <!-- Link to the individual project details -->
        <a href="/project/<%= project.service_project_id %>" class="project-title">
          <strong><%= project.title %></strong>
        </a> 
        - 
        <!-- Link to the organization details -->
        <a href="/organization/<%= project.organization_id %>" class="organization-link">
          <%= project.organization_name %>
        </a>
      </li>
    <% }) %>
  </ul>
  <p><a href="/new-project">Add a New Service Project</a></p>
</main>

<%- include('partials/footer') %>